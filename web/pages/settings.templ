package pages

import "github.com/gregmulvaney/forager/web/components"

templ Settings() {
	@components.Layout("Settings | Forager") {
		<div class="h-16 px-8 flex items-center border-b border-zinc-700">
			<h1 class="text-2xl font-medium">Settings</h1>
		</div>
		<div class="flex flex-1">
			<div class="w-48 border-r border-zinc-700 py-4 px-8">
				<ul>
					<li>Plugins</li>
				</ul>
			</div>
			<div class="flex-1 px-8 py-4">
				content
			</div>
		</div>
	}
}
