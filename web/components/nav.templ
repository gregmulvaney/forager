package components

templ nav() {
	<aside
		class="px-4 flex flex-col fixed inset-y-0 left-0 bg-secondary"
		:class="sidebarOpen ? 'w-60' : 'w-18'"
	>
		<div class="h-16 border-b border-zinc-700">
			<a href="/" class="flex h-16 items-center gap-1">
				<img src="/static/Icon.png" alt="" class="h-10 w-10"/>
				<span class="text-2xl font-medium tracking-wide">Forager</span>
			</a>
		</div>
	</aside>
}
